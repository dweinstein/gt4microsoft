				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:41:39.729048-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:41:39.729048-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "REt1xY6dQPaOlCGIHn8djA=="
				},
				"code" : "config := IntuneGraphClientExamples new clientConfig.\ntenantId := config at: #tenantId.\nclientId := config at: #clientId.\nclientSecret := config at: #clientSecret."
			},
			{
				"__type" : "textSnippet",
