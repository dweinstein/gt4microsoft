				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "## Obtain a token via OAuth (As a Daemon App)"
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:41:51.336147-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:41:51.336147-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "WzWYUYhmQfWKm4p2TLJciw=="
				},
				"code" : "\"POST to the OAuth2 token endpoint with client_credentials grant\"\ntokenEndpoint := 'https://login.microsoftonline.com/' , tenantId , '/oauth2/v2.0/token'.\nresponse := ZnClient new\n\turl: tokenEndpoint;\n\tformAt: 'grant_type' put: 'client_credentials';\n\tformAt: 'client_id' put: clientId;\n\tformAt: 'client_secret' put: clientSecret;\n\tformAt: 'scope' put: 'https://graph.microsoft.com/.default';\n\tpost.\ntoken := (STONJSON fromString: response) at: 'access_token'."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:41:55.294451-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:41:55.294451-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "ZztKMGx5R3iOgIYYwPM7cw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "## Read Mobile Apps\n\nWith the bearer token, query the Graph API directly:"
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:42:00.401505-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:42:00.401505-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "kMbdIk9YSuyuTmeaQkcbaw=="
				},
				"code" : "ZnClient new\n\tforJsonREST;\n\tsetBearerAuthentication: token;\n\turl: 'https://graph.microsoft.com/beta/deviceAppManagement/mobileApps';\n\tget."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
