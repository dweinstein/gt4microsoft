					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-24T12:42:11.545451-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "vtqzRmoiQDG/1CVZJOZMVg=="
				},
				"code" : "config := IntuneGraphClientExamples new clientConfig.\nclient := IntuneGraphClient new\n\ttenantId: (config at: #tenantId);\n\tclientId: (config at: #clientId);\n\tclientSecret: (config at: #clientSecret).\nclient mobileApps."
			}
		]
