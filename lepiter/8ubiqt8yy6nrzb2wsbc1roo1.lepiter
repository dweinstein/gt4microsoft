				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-21T17:22:45.220091-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "vk4ttRs3SNazj6icnet8dw=="
				},
				"code" : "client := IntuneGraphClient new\n\ttenantId: 'your-tenant-id';\n\tclientId: 'your-client-id';\n\tclientSecret: 'your-client-secret'.\nclient mobileApps."
			},
			{
				"__type" : "textSnippet",
