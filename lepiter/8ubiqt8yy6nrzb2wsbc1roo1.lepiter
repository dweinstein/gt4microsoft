				"uid" : {
					"__type" : "uid",
					"uidString" : "6gXD3IJIS/ab4pO6TaLvIA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "{{gtClass:IntuneGraphClient}} is a Microsoft Graph API client for Intune, focused on retrieving Azure Storage SAS URIs for LOB (Line of Business) app binaries.\n\nIt handles OAuth2 client_credentials token flow automatically with expiry-based caching. See {{gtPage:Oauth Flow Microsoft Graph API}} for how to set up an Azure AD app registration with the required permissions.\n\nCredentials can be stored in `~/.secrets/intune-graph-config.json` and loaded via {{gtMethod:IntuneGraphClientExamples>>#clientConfig}}:\n```\n{ \"tenantId\": \"...\", \"clientId\": \"...\", \"clientSecret\": \"/path/to/secret.txt\" }\n```"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-21T17:10:15.034556-04:00"
					}
				},
				"editEmail" : {
